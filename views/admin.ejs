<%- include('templates/header') %>

<h1>Users</h1>

<% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
<% } else { %>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Type</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% for (let user of users) { %>
                <%- include('templates/user', { user: user }) %>
            <% } %>
        </tbody>
    </table>
<% } %>

<%- include('templates/footer') %>